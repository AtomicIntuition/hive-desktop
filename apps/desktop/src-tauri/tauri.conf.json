{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/crates/tauri-utils/schema/config.schema.json",
  "productName": "Hive Desktop",
  "version": "0.2.1",
  "identifier": "ai.hive.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm --filter @hive-desktop/runtime run build:bundle && cp ../../packages/runtime/dist/runtime-bundle.mjs src-tauri/runtime-bundle.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hive Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Hive Desktop"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local AI Agent Workflow Runtime",
    "longDescription": "Hive Desktop is a local-first AI agent workflow runtime. Manage MCP servers, create automations with natural language, and run persistent workflows — all on your machine. Powered by Hive Market.",
    "copyright": "Copyright 2026 Hive",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "createUpdaterArtifacts": false,
    "resources": [
      "runtime-bundle.mjs"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AtomicIntuition/hive-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkgNzY5NzVEODk0QTlCNDlDQgpSV1RMU1p0S2lWMlhkaXJhYzgzek5KVWVVOFE4NUs5dUdHY3dUWG53N0hzY0Y2YTJEbkYzQWZxRQo="
    }
  }
}
