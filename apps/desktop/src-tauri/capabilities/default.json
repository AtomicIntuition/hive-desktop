{
  "identifier": "default",
  "description": "Default capabilities for Hive Desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-kill",
    "notification:default",
    "updater:default",
    "process:allow-restart",
    "process:allow-exit"
  ]
}
