{
  "name": "hive-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Local AI Agent Workflow Runtime \u2014 powered by Hive Market",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "dev:runtime": "turbo dev --filter=@hive-desktop/runtime",
    "dev:desktop": "turbo dev --filter=@hive-desktop/app",
    "build:runtime": "turbo build --filter=@hive-desktop/runtime",
    "build:desktop": "turbo build --filter=@hive-desktop/app"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}